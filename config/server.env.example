# Copy this file to docker/.env.server before running make up.
#
#   cp config/server.env.example docker/.env.server
#   make up
#

# Embeddings: required for vector search.
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# LLM compression: choose one provider.
# Compresses raw observations into memory entries
#
# Default provider: OpenRouter (multi-model, pay-per-use)
#   Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-3.5-haiku   # default model if omitted

# Or use Anthropic directly:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Or Gemini:
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# FEATURES
AGENTMEMORY_TOOLS=all                  # ~51 MCP tools (default ~8)
AGENTMEMORY_INJECT_CONTEXT=true        # add memory context to each tool turn
AGENTMEMORY_AUTO_COMPRESS=true         # compress observations after each tool use
CONSOLIDATION_ENABLED=true             # promote observations to Memories after each session

# CORS: add domain when deploying to a real server.
AGENTMEMORY_CORS_ORIGINS=http://localhost:3111,http://localhost:3113,http://127.0.0.1:3111,http://127.0.0.1:3113
